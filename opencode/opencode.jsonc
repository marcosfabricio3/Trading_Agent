{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "webfetch": "allow",
    "bitget_*": "ask",
    "db_*": "allow"
  },
  "mcp": {
    "bitget": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "bitget-mcp-server",
        "--modules",
        "all"
      ]
    },
    "parser": {
      "type": "stdio",
      "command": "python",
      "args": [
        "./opencode/mcp/parser_server.py"
      ]
    },
    
    "db": {
      "type": "stdio",
      "command": "python",
      "args": [
        "./opencode/mcp/db_server.py"
      ]
    }
  }
}